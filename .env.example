APP_ENV=development
LOG_LEVEL=INFO
JSON_LOGS=false
ACCESS_LOG_ENABLED=true
MAX_REQUEST_BYTES=12582912
WEB_CONCURRENCY=2

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=120
LLM_MAX_CONCURRENCY=8
CHAT_HISTORY_MESSAGES_LIMIT=20

MYSQL_DATABASE=english_ii
MYSQL_USER=english_user
MYSQL_PASSWORD=english_password
MYSQL_ROOT_PASSWORD=jbw261932
DATABASE_URL=mysql+aiomysql://english_user:english_password@localhost:3306/english_ii?charset=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
SQLITE_BUSY_TIMEOUT_SECONDS=30
JWT_SECRET_KEY=7f4d2b9a8c1e4f6a9d3b5e8c2a1f0d7b
ACCESS_TOKEN_EXPIRE_HOURS=24
ADMIN_EMAILS=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

OCR_ENABLED=true
OCR_MAX_CONCURRENCY=2
MAX_IMAGES_PER_REQUEST=9
MAX_IMAGE_BYTES=8388608
MAX_MESSAGE_CHARS=20000

DEFAULT_RATE_LIMIT_PER_MINUTE=100
CHAT_RATE_LIMIT_PER_MINUTE=20
AUTH_RATE_LIMIT_PER_MINUTE=10

REDIS_URL=
REDIS_SOCKET_TIMEOUT_SECONDS=1.0
REDIS_MAX_CONNECTIONS=50
CACHE_DEFAULT_TTL_SECONDS=300

# 默认本地文件存储；生产可切换为 s3，兼容 MinIO/AWS S3。
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/uploads
STORAGE_BASE_URL=http://localhost:8000
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=english-ii-assets
S3_REGION=us-east-1
