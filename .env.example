APP_ENV=development
LOG_LEVEL=INFO
JSON_LOGS=false
ACCESS_LOG_ENABLED=true
MAX_REQUEST_BYTES=12582912

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=120

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
JWT_SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_HOURS=24
ADMIN_EMAILS=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

OCR_ENABLED=true
MAX_IMAGES_PER_REQUEST=9
MAX_IMAGE_BYTES=8388608
MAX_MESSAGE_CHARS=20000

DEFAULT_RATE_LIMIT_PER_MINUTE=100
CHAT_RATE_LIMIT_PER_MINUTE=20
AUTH_RATE_LIMIT_PER_MINUTE=10

REDIS_URL=
CACHE_DEFAULT_TTL_SECONDS=300

# 默认本地文件存储；生产可切换为 s3，兼容 MinIO/AWS S3。
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/uploads
STORAGE_BASE_URL=http://localhost:8000
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=english-ii-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
